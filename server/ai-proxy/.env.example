# AI 代理服务环境变量（复制为 .env 后填入）
#
# cp .env.example .env

# 监听端口（默认 8788，与 deploy.sh / ecosystem 一致时可省略）
# PORT=8788

# CORS 允许来源，自用 * 即可；生产可收紧为具体域名
# ALLOW_ORIGIN=*

# 透明代理模式默认上游（/v1/* 路径，前端自带 key 时用）
# AI_UPSTREAM_HOST=api.openai.com

# Provider 模式 API Key（POST /api/chat，key 存服务端）
XIAOMI_API_KEY=
MINIMAX_API_KEY=
