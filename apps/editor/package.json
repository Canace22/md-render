{
  "name": "@md-render/editor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "MD Render editor app",
  "author": "canace22 <annalovelife39@gmail.com>",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "electron:dev": "ELECTRON=true vite",
    "electron:build": "ELECTRON=true vite build && electron-builder --mac",
    "electron:pack": "ELECTRON=true vite build && electron-builder --mac --dir"
  },
  "dependencies": {
    "@blocknote/core": "0.47.1",
    "@blocknote/mantine": "0.47.1",
    "@blocknote/react": "0.47.1",
    "@md-render/markdown-core": "workspace:*",
    "antd": "^5.28.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.0",
    "lucide-react": "^0.577.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "shiki": "^3.23.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^3.0.5"
  },
  "build": {
    "appId": "com.mdrender.app",
    "productName": "MD Render",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "defaultArch": "universal",
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        }
      ],
      "icon": "build/icon.icns"
    },
    "dmg": {
      "title": "MD Render",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
