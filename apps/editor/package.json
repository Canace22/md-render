{
  "name": "@md-render/editor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "MD Render editor app",
  "author": "canace22 <annalovelife39@gmail.com>",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "electron:dev": "ELECTRON=true vite",
    "electron:build": "node ./scripts/package-electron.mjs build",
    "electron:pack": "node ./scripts/package-electron.mjs pack",
    "electron:rebuild": "npm_config_devdir=.cache/electron-gyp electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@blocknote/core": "0.47.1",
    "@blocknote/mantine": "0.47.1",
    "@blocknote/react": "0.47.1",
    "@md-render/markdown-core": "workspace:*",
    "antd": "^5.28.0",
    "better-sqlite3": "^12.10.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.0",
    "lucide-react": "^0.577.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "shiki": "^3.23.0",
    "turndown": "^7.2.0",
    "mammoth": "^1.9.0",
    "html-to-docx": "^1.8.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.57.0",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^3.0.5"
  },
  "build": {
    "appId": "com.mdrender.app",
    "productName": "MD Render",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Canace22",
        "repo": "md-render"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "defaultArch": "universal",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/icon.icns"
    },
    "dmg": {
      "title": "MD Render",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
