# Dependencies
node_modules/
apps/*/node_modules/
packages/*/node_modules/

# Build output
dist/
apps/*/dist/

# Test output（只忽略产物，保留 tests-unit/ 测试源码）
test-results/
apps/*/test-results/
coverage/
apps/*/coverage/
playwright-report/
apps/*/playwright-report/
.playwright-mcp/

# Environment variables
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Local caches
.cache/
apps/*/.cache/

# Electron
dist-electron/
release/
build/
apps/*/dist-electron/
apps/*/release/
apps/*/build/

# Vitest 加载配置时的临时转译文件（进程被打断时可能残留）
**/vitest.config.*.timestamp-*.mjs
**/vite.config.*.timestamp-*.mjs
